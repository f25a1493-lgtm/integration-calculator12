<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Interactive Integration Calculator</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f0f4f8;
            color: #333;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }
        .controls {
            flex: 1;
            min-width: 280px;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
        }
        .input-group {
            margin-bottom: 12px;
        }
        label {
            display: block;
            font-weight: bold;
            margin-bottom: 5px;
        }
        input, select {
            width: 100%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }
        .result-box {
            margin-top: 20px;
            padding: 15px;
            background: #e3f2fd;
            border-left: 5px solid #2196f3;
            border-radius: 4px;
        }
        .result-value {
            font-size: 22px;
            font-weight: bold;
            color: #0d47a1;
        }
        .canvas-container {
            flex: 1.5;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            border: 1px solid #ddd;
            background: #fff;
            border-radius: 8px;
        }
    </style>
</head>
<body>

<h2 style="text-align: center;">Interactive Integration Calculator</h2>

<div class="container">
    <div class="controls">
        <div class="input-group">
            <label>Function f(x)</label>
            <input type="text" id="fx" value="x*x - 2*x + 3" disabled>
            <small style="color: gray;">Fixed to: x² - 2x + 3</small>
        </div>
        <div class="input-group">
            <label>Lower Bound (a)</label>
            <input type="number" id="boundA" value="0">
        </div>
        <div class="input-group">
            <label>Upper Bound (b)</label>
            <input type="number" id="boundB" value="3">
        </div>
        <div class="input-group">
            <label>Subintervals (n)</label>
            <input type="number" id="intervals" value="100">
        </div>
        <div class="input-group">
            <label>Riemann Sum Type</label>
            <select id="sumType">
                <option value="left">Left Riemann Sum</option>
                <option value="right">Right Riemann Sum</option>
                <option value="midpoint">Midpoint Riemann Sum</option>
                <option value="trapezoid">Trapezoidal Rule</option>
            </select>
        </div>
        
        <div class="result-box">
            <div><strong>Approximated Area:</strong></div>
            <div class="result-value" id="areaResult">0.00000</div>
        </div>
    </div>

    <div class="canvas-container">
        <canvas id="plotCanvas" width="500" height="400"></canvas>
    </div>
</div>

<script>
    const canvas = document.getElementById('plotCanvas');
    const ctx = canvas.getContext('2d');

    const aInput = document.getElementById('boundA');
    const bInput = document.getElementById('boundB');
    const nInput = document.getElementById('intervals');
    const typeInput = document.getElementById('sumType');
    const resultDisplay = document.getElementById('areaResult');

    // Fungsi matematik f(x) = x^2 - 2x + 3
    function f(x) {
        return (x * x) - (2 * x) + 3;
    }

    function drawGraph() {
        const a = parseFloat(aInput.value);
        const b = parseFloat(bInput.value);
        const n = parseInt(nInput.value);
        const type = typeInput.value;

        if (isNaN(a) || isNaN(b) || isNaN(n) || n <= 0) return;

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const pad = 40;
        const w = canvas.width - 2 * pad;
        const h = canvas.height - 2 * pad;

        // Set skala grafik tegap berdasarkan fungsi x^2 - 2x + 3 dari x=-1 ke x=4
        const minX = -1, maxX = 4;
        const minY = 0, maxY = 12;

        function toX(x) { return pad + ((x - minX) / (maxX - minX)) * w; }
        function toY(y) { return canvas.height - pad - ((y - minY) / (maxY - minY)) * h; }

        // Lukis Paksi X & Y
        ctx.strokeStyle = '#ccc';
        ctx.beginPath();
        ctx.moveTo(toX(minX), toY(0)); ctx.lineTo(toX(maxX), toY(0));
        ctx.moveTo(toX(0), toY(minY)); ctx.lineTo(toX(0), toY(maxY));
        ctx.stroke();

        // Kira Kawasan & Lukis Kotak Riemann
        const dx = (b - a) / n;
        let area = 0;

        ctx.fillStyle = 'rgba(33, 150, 243, 0.3)';
        ctx.strokeStyle = '#1976d2';

        for (let i = 0; i < n; i++) {
            let xL = a + i * dx;
            let xR = xL + dx;
            
            ctx.beginPath();
            if (type === 'left') {
                let y = f(xL);
                area += y * dx;
                ctx.rect(toX(xL), toY(y), toX(xR) - toX(xL), toY(0) - toY(y));
            } else if (type === 'right') {
                let y = f(xR);
                area += y * dx;
                ctx.rect(toX(xL), toY(y), toX(xR) - toX(xL), toY(0) - toY(y));
            } else if (type === 'midpoint') {
                let y = f(xL + dx/2);
                area += y * dx;
                ctx.rect(toX(xL), toY(y), toX(xR) - toX(xL), toY(0) - toY(y));
            } else if (type === 'trapezoid') {
                let yL = f(xL);
                let yR = f(xR);
                area += ((yL + yR) / 2) * dx;
                ctx.moveTo(toX(xL), toY(0));
                ctx.lineTo(toX(xL), toY(yL));
                ctx.lineTo(toX(xR), toY(yR));
                ctx.lineTo(toX(xR), toY(0));
                ctx.closePath();
            }
            ctx.fill();
            ctx.stroke();
        }

        // Lukis Garisan Lengkung f(x) warna Merah
        ctx.strokeStyle = '#e53935';
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        for (let sx = 0; sx <= canvas.width; sx++) {
            let pct = (sx - pad) / w;
            let mx = minX + pct * (maxX - minX);
            let my = f(mx);
            if (sx === 0) ctx.moveTo(sx, toY(my));
            else ctx.lineTo(sx, toY(my));
        }
        ctx.stroke();

        // Papar Keputusan Area
        resultDisplay.textContent = area.toFixed(5);
    }

    // Pasang Event Listener untuk Live Update bila ditukar
    [aInput, bInput, nInput, typeInput].forEach(el => {
        el.addEventListener('input', drawGraph);
    });

    // Jalankan lukisan pertama sebaik sahaja halaman dibuka
    drawGraph();
</script>
</body>
</html>
